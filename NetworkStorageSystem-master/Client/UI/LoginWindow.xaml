<Window x:Class="Client.UI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Client.UI"
        mc:Ignorable="d"
        Title="LoginWindow" Height="219" Width="596">
    <Grid>
        <StackPanel Margin="159,31,159,35">

            <TextBox x:Name="UsernameBox"/>

            <PasswordBox x:Name="PasswordBox" Margin="0,10,0,0"/>

            <Button Content="Login" Click="Login_Click" Margin="0,10,0,0"/>
            <Button Content="Register" Click="Register_Click"/>

        </StackPanel>
    </Grid>
</Window>
